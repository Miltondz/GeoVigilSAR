# ─── OpenRouter (AI Assistant) ────────────────────────────────────────────────
# Key gratuita en: https://openrouter.ai — sin tarjeta de crédito
OPENROUTER_API_KEY=sk-or-v1-...

# ── Modelos GRATUITOS (verificado 2026-06-26, pricing.prompt = $0) ─────────────
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free  ← RECOMENDADO · 70B · 131K ctx · multilingual
# OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free   ← 80B MoE · 262K ctx · razonamiento/multilingual
# OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-405b:free ← 405B (!!) · 131K ctx · agentic
# OPENROUTER_MODEL=google/gemma-4-31b-it:free              ← 31B · 262K ctx · multimodal (text+img+video)
# OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free          ← 26B MoE · 262K ctx · multimodal
# OPENROUTER_MODEL=openrouter/free                         ← router aleatorio entre todos los modelos gratis

# Default activo (cambiar aquí o en .env.local):
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Modelos DE PAGO (mayor disponibilidad, sin rate limits) ───────────────────
# OPENROUTER_MODEL=openai/gpt-4o-mini              ← $0.15/M in · $0.60/M out
# OPENROUTER_MODEL=google/gemini-flash-1.5         ← $0.075/M in · $0.30/M out (más barato)
# OPENROUTER_MODEL=anthropic/claude-3-haiku        ← $0.25/M in · $1.25/M out
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet     ← $3.00/M in · $15.00/M out
# OPENROUTER_MODEL=openai/gpt-4o                   ← $2.50/M in · $10.00/M out

# URL del sitio (enviada a OpenRouter para atribución)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Convex (opcional — cache + tiempo real) ──────────────────────────────────
# App funciona sin Convex usando llamadas directas + caché de Next.js
CONVEX_DEPLOYMENT=dev:your-project-name-xxx
NEXT_PUBLIC_CONVEX_URL=https://your-project-name-xxx.convex.cloud

# ─── Mapillary (opcional — fotos street-level) ────────────────────────────────
# https://www.mapillary.com/developer — gratis, 50k req/mes
MAPILLARY_CLIENT_TOKEN=MLY|...

# ─── NASA FIRMS (opcional — capa de calor/fuego) ──────────────────────────────
# https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_MAP_KEY=

# ─── Copernicus Dataspace — Sentinel-1 SAR + Sentinel-2 ──────────────────────
# https://dataspace.copernicus.eu — cuenta gratuita requerida
COPERNICUS_USERNAME=your-email@example.com
COPERNICUS_PASSWORD=your-password

# ─── Feature flags ────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_SAR_LAYERS=false
NEXT_PUBLIC_ENABLE_MAPILLARY=false
