# ─── OpenRouter (AI Assistant) ────────────────────────────────────────────────
# Get free key at: https://openrouter.ai
# Free models available — no credit card needed for free tier
OPENROUTER_API_KEY=sk-or-v1-...

# Model to use (default: openai/gpt-4o-mini)
# Free options:   meta-llama/llama-3.1-8b-instruct:free
#                 google/gemma-2-9b-it:free
#                 mistralai/mistral-7b-instruct:free
# Cheap options:  openai/gpt-4o-mini  ($0.15/M tokens)
#                 anthropic/claude-3-haiku  ($0.25/M tokens)
# Better options: anthropic/claude-3.5-sonnet  ($3/M tokens)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Site URL (sent to OpenRouter for attribution)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Convex ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.convex.dev → your project → Settings
# Optional for Phase 1-5 (app works without Convex using direct API calls)
CONVEX_DEPLOYMENT=dev:your-project-name-xxx
NEXT_PUBLIC_CONVEX_URL=https://your-project-name-xxx.convex.cloud

# ─── Mapillary ────────────────────────────────────────────────────────────────
# Get from: https://www.mapillary.com/developer — free, 50k req/month
# Optional: used for street-level pre-event photos at damage points
MAPILLARY_CLIENT_TOKEN=MLY|...

# ─── NASA FIRMS ───────────────────────────────────────────────────────────────
# Get from: https://firms.modaps.eosdis.nasa.gov/api/area/
# Optional: used for heat source layer
NASA_FIRMS_MAP_KEY=

# ─── Feature flags ────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_SAR_LAYERS=false
NEXT_PUBLIC_ENABLE_MAPILLARY=false
