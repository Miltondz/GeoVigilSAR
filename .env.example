# ─── Convex ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.convex.dev → your project → Settings
CONVEX_DEPLOYMENT=dev:your-project-name-xxx
NEXT_PUBLIC_CONVEX_URL=https://your-project-name-xxx.convex.cloud

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Mapillary ────────────────────────────────────────────────────────────────
# Get from: https://www.mapillary.com/developer — free, 50k req/month
# Used for street-level pre-event photos at damage points
MAPILLARY_CLIENT_TOKEN=MLY|...

# ─── MapTiler (optional fallback tiles) ───────────────────────────────────────
# Primary: Protomaps (no key needed, self-hosted tiles)
# Fallback: MapTiler free tier — https://cloud.maptiler.com/account/keys/
NEXT_PUBLIC_MAPTILER_KEY=

# ─── NASA FIRMS ───────────────────────────────────────────────────────────────
# Get from: https://firms.modaps.eosdis.nasa.gov/api/area/
# Free with registration — 500k req/day
NASA_FIRMS_MAP_KEY=

# ─── Feature flags ────────────────────────────────────────────────────────────
# Set to "true" to enable features not yet fully integrated
NEXT_PUBLIC_ENABLE_SAR_LAYERS=false
NEXT_PUBLIC_ENABLE_AI_PANEL=false
NEXT_PUBLIC_ENABLE_MAPILLARY=false
